{
  "name": "f1aire",
  "version": "0.0.0",
  "description": "An F1 AI race engineer chat agent (terminal UI).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shayne/f1aire.git"
  },
  "bugs": {
    "url": "https://github.com/shayne/f1aire/issues"
  },
  "homepage": "https://github.com/shayne/f1aire#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "imports": {
    "#ink": {
      "types": "./src/ink/index.ts",
      "f1aire-source": "./src/ink/index.ts",
      "default": "./dist/ink/index.js"
    },
    "#ink/testing": {
      "types": "./src/ink/testing.tsx",
      "f1aire-source": "./src/ink/testing.tsx",
      "default": "./dist/ink/testing.js"
    }
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "bin": {
    "f1aire": "dist/index.js"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=f1aire-source tsx src/index.tsx",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "NODE_OPTIONS=--conditions=f1aire-source vitest run",
    "check:openai": "tsx scripts/check-openai.ts",
    "test:e2e": "NODE_OPTIONS=--conditions=f1aire-source F1AIRE_E2E=1 vitest run src/agent/openai-stream.e2e.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.24",
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@inkkit/ink-markdown": "^1.0.0",
    "@microsoft/signalr": "^10.0.0",
    "ai": "^6.0.66",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.6.0",
    "esbuild": "^0.27.2",
    "get-east-asian-width": "^1.5.0",
    "indent-string": "^5.0.0",
    "ink": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "lodash-es": "^4.17.23",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "pyodide": "^0.29.3",
    "react": "^18.3.1",
    "react-reconciler": "^0.29.2",
    "semver": "^7.7.4",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "tar": "^7.4.0",
    "type-fest": "^5.5.0",
    "unbzip2-stream": "^1.4.3",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0",
    "yoga-layout": "~3.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
